datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Voucher {
  id          String    @id @default(cuid())
  code        String    @unique
  durationMin Int
  price       Float
  isUsed      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  activatedAt DateTime?
}

model ActiveSession {
  id          String    @id @default(cuid())
  macAddress  String    @unique
  ipAddress   String
  voucherCode String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}